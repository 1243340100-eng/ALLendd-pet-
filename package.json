{
  "name": "electron-pet-framework",
  "version": "1.4.2",
  "description": "A reusable Electron desktop pet framework with AI chat, memory, reminders, and placeholder test mode.",
  "main": "app/main.js",
  "author": "Codex",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable",
    "test:harness": "node app/services/conversation-harness/tests/analyzer.test.js && node app/services/conversation-harness/tests/policy.test.js && node app/services/conversation-harness/tests/playfulness.test.js && node app/services/conversation-harness/tests/boundary.test.js && node app/services/conversation-harness/tests/post-check.test.js",
    "test:character": "node app/services/conversation-harness/tests/character-fidelity.test.js",
    "demo:harness": "node app/services/conversation-harness/demo/run-demo.js"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "local.pet.framework",
    "productName": "PetFramework",
    "electronVersion": "31.7.7",
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "app/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
